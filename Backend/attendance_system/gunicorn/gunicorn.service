[Unit]
Description=gunicorn daemon
Requires=gunicorn.socket
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/project/attendance/Backend/attendance_system
ExecStart=/home/ubuntu/project/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/run/gunicorn.sock \
          attendance_system.wsgi:application
[Install]
WantedBy=multi-user.target
